generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  handicap     Float         @default(54.0)
  pushToken    String?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  rounds       Round[]
  groupMembers GroupMember[]
  swingVideos  SwingVideo[]

  @@map("users")
}

model Group {
  id        String        @id @default(cuid())
  name      String
  code      String        @unique
  creatorId String
  createdAt DateTime      @default(now())
  members   GroupMember[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Course {
  id        String       @id @default(cuid())
  name      String
  city      String
  country   String
  latitude  Float
  longitude Float
  holes     Int          @default(18)
  par       Int
  rounds    Round[]
  courseHoles CourseHole[]

  @@map("courses")
}

model CourseHole {
  id        String  @id @default(cuid())
  courseId   String
  number    Int
  par       Int
  distance  Int
  latitude  Float?
  longitude Float?
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, number])
  @@map("course_holes")
}

model Round {
  id         String      @id @default(cuid())
  userId     String
  courseId    String
  date       DateTime    @default(now())
  totalScore Int
  totalPar   Int
  weather    String?
  notes      String?
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  scores      HoleScore[]
  swingVideos SwingVideo[]

  @@map("rounds")
}

model HoleScore {
  id      String   @id @default(cuid())
  roundId String
  hole    Int
  score   Int
  putts   Int?
  fairway Boolean?
  gir     Boolean?
  round   Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, hole])
  @@map("hole_scores")
}

model SwingVideo {
  id        String   @id @default(cuid())
  userId    String
  roundId   String?
  hole      Int?
  club      String?
  videoUrl  String
  duration  Float?
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  round     Round?   @relation(fields: [roundId], references: [id], onDelete: SetNull)

  @@map("swing_videos")
}
